              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{userId}}"]
            },
            "description": "Update user information\n\nRequires: Authentication (any authenticated user)"
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
